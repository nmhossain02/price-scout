# The Docker demo starts without external credentials. Copy this file to .env
# only when you want to change defaults or scan live public product pages.
SCOUT_PUBLIC_URL=http://127.0.0.1:3000
DATABASE_URL=postgres://scout:scout@postgres:5432/scout?sslmode=disable
NATS_URL=nats://nats:4222
WORKER_API_TOKEN=local-development-token-change-me
NAVIGATION_TIMEOUT_MS=30000
CONTROL_PLANE_TIMEOUT_MS=15000
JOB_TIMEOUT_MS=120000

# local or browserbase
BROWSER_PROVIDER=LOCAL
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# auto uses the credential-free scripted compiler only for the configured
# fixture origin and live inference for other public pages. `scripted` is a
# fixture-only override; `live` forces inference everywhere.
INFERENCE_MODE=auto
STAGEHAND_MODEL=openai/gpt-4.1-mini
MODEL_API_KEY=

# One installation-wide destination of each type is supported in v1.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
DISCORD_WEBHOOK_URL=

# Safety and scheduling defaults.
DEFAULT_INTERVAL_MINUTES=360
MIN_INTERVAL_MINUTES=15
SCOUT_EXECUTION_RUNNING_STALE_AFTER=5m
SCOUT_EXECUTION_MAX_ATTEMPTS=3
SCOUT_FIXTURE_ORIGIN=http://fixture:4173
